{
    "manifest_version": 3,
    "name": "Hatsune Miku <3",
    "version": "6.9",
    "description": ":3",
    "permissions": [
      "tabs",
      "storage"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_icon": "icon.png"
    },
    "chrome_url_overrides": {
      "newtab": "new-tab.html"
    },
    "icons": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ]
  }
  